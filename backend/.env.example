# MongoDB Atlas 연결 문자열
# MongoDB Atlas → Connect → Drivers → 복사한 URI 붙여넣기
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ghosttracker?retryWrites=true&w=majority

# 서버 포트 (로컬 개발용, Render는 자동 설정)
PORT=4000

# 허용할 쇼핑몰 도메인 (콤마로 구분)
# 예: https://jh-web-nu.vercel.app,https://other-shop.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://jh-web-nu.vercel.app
